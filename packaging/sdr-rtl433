#!/bin/sh
# czconsole SDR rtl_433 wrapper. Run by czconsole-rtl433.service as the
# operator user. Parameters arrive as env vars via systemd EnvironmentFile.
# Creates ~/SDR/ and runs rtl_433, optionally wrapped in timeout.
set -e

SDR_DIR="${HOME}/SDR"
mkdir -p "$SDR_DIR"

TS=$(date +%Y-%m-%d-%H-%M-%S)
JSON="${SDR_DIR}/rtl_433-${TS}.json"
TXT="${SDR_DIR}/rtl_433-${TS}.txt"

if [ "${SDR_DURATION:-300}" = "0" ]; then
    # Continuous mode: run until systemctl stop (SIGTERM)
    exec rtl_433 \
        -f "${SDR_FREQ_MHZ}M" -g "$SDR_GAIN" -s "${SDR_BW_KHZ}k" \
        -F "json:${JSON}" -F "kv:${TXT}"
else
    exec timeout "$SDR_DURATION" \
        rtl_433 \
        -f "${SDR_FREQ_MHZ}M" -g "$SDR_GAIN" -s "${SDR_BW_KHZ}k" \
        -F "json:${JSON}" -F "kv:${TXT}"
fi
