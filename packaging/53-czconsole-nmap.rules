// Allow the deprivileged czconsole web worker (_czconsole) to start/stop the
// nmap scan unit. The worker writes the validated CLI options to an env file in
// /run/czconsole/ then starts the unit; the unit (as the operator user) reads
// the env file and runs nmap with the unit-scoped CAP_NET_RAW. No setuid, and
// the cap lives on the unit, not on /usr/bin/nmap — see czconsole-nmap.service.
//
// Install to /etc/polkit-1/rules.d/53-czconsole-nmap.rules
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "_czconsole") {
        var unit = action.lookup("unit");
        if (unit == "czconsole-nmap.service") {
            return polkit.Result.YES;
        }
    }
});
