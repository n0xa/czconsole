// Allow the deprivileged czconsole web worker (_czconsole) to start/stop the
// gobuster scan unit. The worker writes the validated inputs to an env file in
// /run/czconsole/ then starts the unit; the unit (as the operator user) reads it
// and runs gobuster. No setuid, no special caps.
//
// Install to /etc/polkit-1/rules.d/54-czconsole-gobuster.rules
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "_czconsole") {
        var unit = action.lookup("unit");
        if (unit == "czconsole-gobuster.service") {
            return polkit.Result.YES;
        }
    }
});
