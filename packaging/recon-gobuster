#!/bin/sh
# czconsole gobuster wrapper. Run by czconsole-gobuster.service as the OPERATOR
# user. Inputs arrive as env vars via the unit's EnvironmentFile, written by the
# czconsole core just before the unit is started.
#
# Output convention (shared by every recon tool): a timestamped file under the
# operator's ~/gobuster/, readable by the deprivileged frontends (see the privsep
# notes in docs/native-lcd.md). The WHOLE run — gobuster's banner, the findings,
# and any errors — is captured to one .txt (2>&1); the frontends parse the
# banner for the header and the "(Status: NNN)" lines for findings.
set -e

DIR="${HOME}/gobuster"
mkdir -p "$DIR"   # normally pre-created (setgid czconsole) by the postinstall

TS=$(date +%Y-%m-%d-%H-%M-%S)
TXT="${DIR}/gobuster-${TS}.txt"

# URL and WORDLIST are single values → QUOTED (injection-safe). GOBUSTER_OPTS is
# left unquoted so the shell word-splits it into argv (a ';'/'|'/'&' inside the
# value is an inert literal arg, never a new command — the same property the
# nmap wrapper relies on). `dir` mode is implied by this menu-driven UI.
exec gobuster dir -u "$GOBUSTER_URL" -w "$GOBUSTER_WORDLIST" $GOBUSTER_OPTS > "$TXT" 2>&1
