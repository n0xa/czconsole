#!/bin/sh
# czconsole SDR rtl_power wrapper. Run by czconsole-rtlpower.service as the
# operator user. Parameters arrive as env vars via systemd EnvironmentFile.
# Creates ~/SDR/, runs rtl_power, then (if SDR_HEATMAP=1) generates a PNG.
set -e

SDR_DIR="${HOME}/SDR"
mkdir -p "$SDR_DIR"

TS=$(date +%Y-%m-%d-%H-%M-%S)
OUT="${SDR_DIR}/rtl_power-${TS}.csv"

if [ "${SDR_DURATION:-300}" = "0" ]; then
    # Single shot: capture one full pass then exit
    rtl_power \
        -f "${SDR_LOW_MHZ}M:${SDR_HIGH_MHZ}M:${SDR_BIN_KHZ}k" \
        -g "$SDR_GAIN" -c "$SDR_CROP" -i "$SDR_INTEGRATION" \
        -1 "$OUT"
else
    rtl_power \
        -f "${SDR_LOW_MHZ}M:${SDR_HIGH_MHZ}M:${SDR_BIN_KHZ}k" \
        -g "$SDR_GAIN" -c "$SDR_CROP" -i "$SDR_INTEGRATION" \
        -e "$SDR_DURATION" "$OUT"
fi

# Generate heatmap PNG after a successful capture. || true so a failed
# rfheatmap (e.g. empty CSV) doesn't mark the unit as failed.
if [ "${SDR_HEATMAP:-0}" = "1" ] && command -v rfheatmap >/dev/null 2>&1; then
    rfheatmap -o "${OUT%.csv}.png" "$OUT" || true
fi
